# ===========================================================================
# LiteYuki SRE Agent 环境配置模板
# ===========================================================================
# 复制为 .env 并填写实际值。容器化部署直接注入环境变量。
# [必填] = 必须配置   [可选] = 有默认值，按需修改

# [可选] Google Gemini（使用 Gemini 模型时需要）
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=

# [可选] 全局 LLM 模型配置，所有 Agent 默认使用
AGENT_MODEL=deepseek/deepseek-v4-flash
# [必填] LLM API 密钥（使用非 Gemini 模型时必须提供）
AGENT_TOKEN=你的_deepseek_api_key
# [可选] LLM API 地址，默认 DeepSeek 官方
AGENT_API=https://api.deepseek.com

# [必填] JWT 签名密钥，用于用户认证令牌签发。请使用随机字符串
SECRET_KEY=请替换为随机字符串

# [必填] 后端公开访问地址（OAuth 回调需要完整 URL）
SERVER_HOST=http://localhost:8000

# [可选] 数据库连接地址，默认 SQLite
DATABASE_URL=sqlite+aiosqlite:///./data.db

# [可选] CORS 允许的前端来源，逗号分隔
CORS_ORIGINS=http://localhost:5173

# [可选] 初始超级用户账号密码（首次启动自动创建，请及时修改）
INITIAL_USERNAME=admin
INITIAL_PASSWORD=admin

# ---------------------------------------------------------------------------
# PostgreSQL（取消注释并注释掉上面的 SQLite DATABASE_URL）
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://liteyuki:liteyuki@postgres:5432/liteyuki_sre
# POSTGRES_USER=liteyuki
# POSTGRES_PASSWORD=liteyuki
# POSTGRES_DB=liteyuki_sre
